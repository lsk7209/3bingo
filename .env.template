
# ─── 토스 앱인토스 환경변수 ────────────────────────────────────────────────────
# 토스 디벨로퍼스(developers.toss.im)에서 발급받은 값을 사용하세요.
# 이 파일을 복사하여 .env 파일을 생성 후 실제 값을 입력하세요.

# ─── Backend 전용 (서버 시크릿 — 절대 공개 금지) ───────────────────────────────
TOSS_CLIENT_ID=
TOSS_SECRET_KEY=

# mTLS 인증서 경로 (토스 디벨로퍼스에서 발급)
MTLS_CERT_PATH=./certs/toss_cert.pem
MTLS_KEY_PATH=./certs/toss_key.pem

# CORS 허용 Origin (콤마로 복수 지정 가능)
ALLOWED_ORIGINS=https://miniapp.toss.im

# 서버 포트
PORT=8080

# 실행 환경 (development | production)
NODE_ENV=development

# ─── Frontend 전용 (NEXT_PUBLIC_ prefix — 클라이언트에 노출됨) ─────────────────
# 광고 유닛 ID (앱인토스 광고 플랫폼에서 발급)
NEXT_PUBLIC_AD_BANNER_ID=
NEXT_PUBLIC_AD_INTERSTITIAL_ID=

# 백엔드 API URL (프론트에서 호출 시 사용)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
